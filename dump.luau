local _LPH_SRC = ""

local OUT_STRINGS = "luraph_strings_dump.txt"
local OUT_PROTOS = "luraph_protos_dump.tsv"
local OUT_OBJECTS = "luraph_objects_dump.tsv"
local OUT_RELATIONS = "luraph_relations_dump.tsv"
local OUT_CONSTANTS = "luraph_constants_dump.tsv"
local OUT_META = "luraph_metadata.txt"

local POLL_TRIES = 30
local POLL_GAP = 3
local EXEC_WAIT = 3
local SLICE = 2500

local MAX_FIELD = 24
local MAX_ARRAY_SCAN = 4096
local MAX_TABLE_KEYS = 1024
local MAX_RECURSION = 6

local MIN_PROTO_SCORE = 14
local MIN_CODE_LENGTH = 2
local MAX_CANDIDATES = 10000

local warn = warn or print
local getgc = getgc or get_gc_objects or (debug and debug.getgc)
local writefile = writefile or write_file

if not getgc or not writefile then
    warn("[dump] need getgc + writefile")
    return
end

pcall(function()
    local genv = (getgenv and getgenv()) or _G
    genv.SCRIPT_KEY = "__PUT_YOUR_KEY_HERE__"
    genv.script_key = "__PUT_YOUR_KEY_HERE__"
end)

local function fromhex(h)
    return h:gsub("..", function(c)
        return string.char(tonumber(c, 16))
    end)
end

local SRC = fromhex(_LPH_SRC)

local function spawn(fn)
    if task and task.spawn then
        return task.spawn(fn)
    end

    local co = coroutine.create(fn)
    return coroutine.resume(co)
end

local function wait_(t)
    if task and task.wait then
        return task.wait(t)
    elseif wait then
        return wait(t)
    end
end

local function get_objects()
    local ok, objects = pcall(function()
        return getgc(true)
    end)

    if ok and type(objects) == "table" then
        return objects
    end

    ok, objects = pcall(function()
        return getgc()
    end)

    if ok and type(objects) == "table" then
        return objects
    end

    return nil
end

local function safe_rawget(t, k)
    local ok, value = pcall(rawget, t, k)

    if ok then
        return value
    end

    return nil
end

local function safe_len(t)
    local ok, n = pcall(function()
        return #t
    end)

    if ok and type(n) == "number" then
        return n
    end

    return 0
end

local function array_info(t)
    if type(t) ~= "table" then
        return 0, 0, 0
    end

    local length = safe_len(t)

    if length <= 0 then
        return 0, 0, 0
    end

    local numbers = 0
    local strings = 0
    local nonnil = 0

    local limit = math.min(
        length,
        MAX_ARRAY_SCAN
    )

    for i = 1, limit do
        local v = safe_rawget(t, i)

        if v ~= nil then
            nonnil = nonnil + 1
        end

        if type(v) == "number" then
            numbers = numbers + 1
        elseif type(v) == "string" then
            strings = strings + 1
        end
    end

    return length, numbers, strings
end

local function is_array(t)
    if type(t) ~= "table" then
        return false
    end

    local length = safe_len(t)

    return length >= 2
        and length <= MAX_ARRAY_SCAN
end

local function is_numeric_array(t)
    local length, numbers = array_info(t)

    if length < 2 then
        return false
    end

    return numbers >= math.max(
        2,
        math.floor(length * 0.65)
    )
end

local function is_primitive(v)
    local t = type(v)

    return t == "nil"
        or t == "number"
        or t == "string"
        or t == "boolean"
end

local function hex_encode(s)
    return s:gsub(".", function(ch)
        return string.format(
            "%02x",
            string.byte(ch)
        )
    end)
end

local function readable(s)
    if type(s) ~= "string" then
        return false
    end

    local n = #s

    if n < 3 or n > 512 then
        return false
    end

    local printable = 0

    for i = 1, n do
        local b = string.byte(s, i)

        if b >= 32 and b < 127 then
            printable = printable + 1
        end
    end

    return printable / n >= 0.85
end

local function value_signature(v)
    local t = type(v)

    if t == "nil" then
        return "nil"

    elseif t == "number" then
        return "number:" .. tostring(v)

    elseif t == "string" then
        return "string:" .. hex_encode(v)

    elseif t == "boolean" then
        return "boolean:" .. tostring(v)

    elseif t == "table" then
        return "table"

    elseif t == "function" then
        return "function"

    elseif t == "userdata" then
        return "userdata"

    elseif t == "thread" then
        return "thread"
    end

    return t
end

local function parallel_score(t, code_field)
    local code = safe_rawget(t, code_field)

    if type(code) ~= "table" then
        return 0
    end

    local code_len = safe_len(code)

    if code_len < MIN_CODE_LENGTH then
        return 0
    end

    local score = 0
    local matching = 0
    local arrays = 0

    for f = 1, MAX_FIELD do
        if f ~= code_field then
            local v = safe_rawget(t, f)

            if type(v) == "table" then
                arrays = arrays + 1

                local len = safe_len(v)

                if len == code_len then
                    matching = matching + 1
                elseif math.abs(len - code_len) <= 1 then
                    matching = matching + 1
                end
            end
        end
    end

    score = score + matching * 3
    score = score + math.min(arrays, 6)

    return score
end

local function proto_score(t, code_field)
    if type(t) ~= "table" then
        return 0
    end

    local code = safe_rawget(t, code_field)

    if type(code) ~= "table" then
        return 0
    end

    local length, numbers = array_info(code)

    if length < MIN_CODE_LENGTH then
        return 0
    end

    local score = 0

    score = score + 5

    if numbers >= math.max(
        2,
        math.floor(length * 0.65)
    ) then
        score = score + 5
    end

    if length >= 4 then
        score = score + 2
    end

    score = score + parallel_score(
        t,
        code_field
    )

    local table_fields = 0
    local numeric_arrays = 0
    local primitive_arrays = 0

    for f = 1, MAX_FIELD do
        if f ~= code_field then
            local v = safe_rawget(t, f)

            if type(v) == "table" then
                table_fields = table_fields + 1

                if is_numeric_array(v) then
                    numeric_arrays = numeric_arrays + 1
                end

                if is_array(v) then
                    local len = safe_len(v)
                    local primitives = 0

                    for i = 1, math.min(
                        len,
                        128
                    ) do
                        if is_primitive(
                            safe_rawget(v, i)
                        ) then
                            primitives = primitives + 1
                        end
                    end

                    if primitives >= math.max(
                        2,
                        math.floor(
                            math.min(len, 128)
                            * 0.5
                        )
                    ) then
                        primitive_arrays =
                            primitive_arrays + 1
                    end
                end
            end
        end
    end

    if table_fields >= 3 then
        score = score + 3
    end

    if numeric_arrays >= 2 then
        score = score + 3
    end

    if primitive_arrays >= 2 then
        score = score + 2
    end

    return score
end

local function find_code_field(t)
    local best_field = nil
    local best_score = 0

    for f = 1, MAX_FIELD do
        local score = proto_score(
            t,
            f
        )

        if score > best_score then
            best_score = score
            best_field = f
        end
    end

    return best_field, best_score
end

local function write_value(v)
    local t = type(v)

    if t == "nil" then
        return "nil"

    elseif t == "number" then
        return "number:" .. tostring(v)

    elseif t == "string" then
        return "string_hex:" ..
            hex_encode(v)

    elseif t == "boolean" then
        return "boolean:" ..
            tostring(v)

    elseif t == "table" then
        return "table"

    elseif t == "function" then
        return "function"

    elseif t == "userdata" then
        return "userdata"

    elseif t == "thread" then
        return "thread"
    end

    return t
end

local function snapshot_gc()
    local objects = get_objects()
    local snapshot = {}

    if type(objects) ~= "table" then
        return snapshot
    end

    for _, object in pairs(objects) do
        snapshot[object] = true
    end

    return snapshot
end

local function dump_now(objs)
    local candidates = {}

    local code_votes = {}

    for _, object in pairs(objs) do
        if type(object) == "table" then
            local field, score =
                find_code_field(object)

            if field
                and score >= MIN_PROTO_SCORE then

                candidates[#candidates + 1] = {
                    object = object,
                    field = field,
                    score = score
                }

                code_votes[field] =
                    (code_votes[field] or 0) + 1
            end
        end
    end

    if #candidates == 0 then
        return false, {}
    end

    table.sort(
        candidates,
        function(a, b)
            return a.score > b.score
        end
    )

    if #candidates > MAX_CANDIDATES then
        while #candidates > MAX_CANDIDATES do
            candidates[#candidates] = nil
        end
    end

    local dominant_field = nil
    local dominant_votes = 0

    for field, votes in pairs(
        code_votes
    ) do
        if votes > dominant_votes then
            dominant_field = field
            dominant_votes = votes
        end
    end

    if not dominant_field then
        return false, {}
    end

    local protos = {}
    local pseen = {}

    for _, candidate in ipairs(
        candidates
    ) do
        if candidate.field ==
            dominant_field then

            local object = candidate.object

            if not pseen[object] then
                pseen[object] = true

                protos[#protos + 1] = {
                    object = object,
                    field = candidate.field,
                    score = candidate.score
                }
            end
        end
    end

    if #protos == 0 then
        return false, {}
    end

    local index = {}

    for i, proto in ipairs(protos) do
        index[proto.object] = i
    end

    local strings = {}
    local string_seen = {}

    local constants = {}
    local constant_seen = {}

    local relations = {}

    local function add_string(s)
        if type(s) == "string"
            and readable(s)
            and not string_seen[s] then

            string_seen[s] = true
            strings[#strings + 1] = s
        end
    end

    local function add_constant(v)
        if is_primitive(v) then
            local sig = value_signature(v)

            if not constant_seen[sig] then
                constant_seen[sig] = true

                constants[#constants + 1] = {
                    signature = sig,
                    value = v
                }
            end
        end
    end

    for id, proto in ipairs(protos) do
        local S = proto.object
        local CF = proto.field

        local code = safe_rawget(S, CF)

        if type(code) == "table" then
            local code_len = safe_len(code)

            for i = 1, code_len do
                local opcode = safe_rawget(
                    code,
                    i
                )

                add_constant(opcode)

                for f = 1, MAX_FIELD do
                    if f ~= CF then
                        local arr =
                            safe_rawget(
                                S,
                                f
                            )

                        if type(arr) ==
                            "table" then

                            local v =
                                safe_rawget(
                                    arr,
                                    i
                                )

                            add_constant(v)

                            if type(v) ==
                                "string" then
                                add_string(v)
                            end

                            if type(v) ==
                                "table" then

                                local child =
                                    index[v]

                                if child then
                                    relations[
                                        #relations + 1
                                    ] =
                                        {
                                            parent = id,
                                            child = child,
                                            instruction = i,
                                            field = f
                                        }
                                end
                            end
                        end
                    end
                end
            end
        end

        if id % 50 == 0 then
            wait_()
        end
    end

    table.sort(
        strings
    )

    writefile(
        OUT_STRINGS,
        table.concat(
            strings,
            "\n"
        )
    )

    local proto_out = {
        "CODEFIELD\t" ..
            tostring(dominant_field),

        "ROOTS\t" ..
            tostring(#protos)
    }

    for id, proto in ipairs(protos) do
        local S = proto.object
        local CF = proto.field
        local code = safe_rawget(
            S,
            CF
        )

        local code_len = safe_len(
            code
        )

        proto_out[#proto_out + 1] =
            table.concat(
                {
                    "PROTO",
                    id,
                    code_len,
                    proto.score,
                    CF
                },
                "\t"
            )

        for i = 1, code_len do
            local row = {
                "I",
                i,
                write_value(
                    safe_rawget(
                        code,
                        i
                    )
                )
            }

            for f = 1, MAX_FIELD do
                if f ~= CF then
                    local arr =
                        safe_rawget(
                            S,
                            f
                        )

                    local value = nil

                    if type(arr) ==
                        "table" then
                        value =
                            safe_rawget(
                                arr,
                                i
                            )
                    end

                    row[#row + 1] =
                        "f" ..
                        f ..
                        "=" ..
                        write_value(
                            value
                        )
                end
            end

            proto_out[#proto_out + 1] =
                table.concat(
                    row,
                    "\t"
                )
        end

        proto_out[#proto_out + 1] =
            "ENDPROTO"
    end

    writefile(
        OUT_PROTOS,
        table.concat(
            proto_out,
            "\n"
        )
    )

    local constant_out = {
        "TYPE\tVALUE"
    }

    for _, constant in ipairs(
        constants
    ) do
        constant_out[#constant_out + 1] =
            constant.signature
    end

    writefile(
        OUT_CONSTANTS,
        table.concat(
            constant_out,
            "\n"
        )
    )

    local relation_out = {
        "PARENT\tCHILD\tINSTRUCTION\tFIELD"
    }

    local relation_seen = {}

    for _, relation in ipairs(
        relations
    ) do
        local key =
            relation.parent ..
            ":" ..
            relation.child ..
            ":" ..
            relation.instruction ..
            ":" ..
            relation.field

        if not relation_seen[key] then
            relation_seen[key] = true

            relation_out[#relation_out + 1] =
                table.concat(
                    {
                        relation.parent,
                        relation.child,
                        relation.instruction,
                        relation.field
                    },
                    "\t"
                )
        end
    end

    writefile(
        OUT_RELATIONS,
        table.concat(
            relation_out,
            "\n"
        )
    )

    local object_out = {
        "ID\tSCORE\tCODEFIELD\tCODELEN"
    }

    for id, proto in ipairs(
        protos
    ) do
        local code =
            safe_rawget(
                proto.object,
                proto.field
            )

        object_out[#object_out + 1] =
            table.concat(
                {
                    id,
                    proto.score,
                    proto.field,
                    safe_len(code)
                },
                "\t"
            )
    end

    writefile(
        OUT_OBJECTS,
        table.concat(
            object_out,
            "\n"
        )
    )

    local metadata = {
        "PROTO_COUNT=" ..
            tostring(#protos),

        "STRING_COUNT=" ..
            tostring(#strings),

        "CONSTANT_COUNT=" ..
            tostring(#constants),

        "RELATION_COUNT=" ..
            tostring(#relations),

        "DOMINANT_CODE_FIELD=" ..
            tostring(dominant_field),

        "DOMINANT_CODE_FIELD_VOTES=" ..
            tostring(dominant_votes)
    }

    writefile(
        OUT_META,
        table.concat(
            metadata,
            "\n"
        )
    )

    warn(
        string.format(
            "[dump] DONE | protos=%d strings=%d constants=%d relations=%d field=%d",
            #protos,
            #strings,
            #constants,
            #relations,
            dominant_field
        )
    )

    return true, {
        [dominant_field] =
            dominant_votes
    }
end

spawn(function()
    warn(
        "[dump] taking pre-execution snapshot"
    )

    local before =
        snapshot_gc()

    local f, err =
        loadstring(
            SRC,
            "=luraph"
        )

    if not f then
        warn(
            "[dump] loadstring failed: " ..
            tostring(err)
        )

        return
    end

    local ok, result =
        pcall(f)

    warn(
        "[dump] script returned ok=" ..
        tostring(ok) ..
        " " ..
        tostring(result)
    )

    wait_(
        EXEC_WAIT
    )

    for attempt = 1,
        POLL_TRIES do

        local objects =
            get_objects()

        if type(objects) ==
            "table" then

            local target_objects =
                {}

            for _, object in pairs(
                objects
            ) do
                if not before[object] then
                    target_objects[
                        #target_objects + 1
                    ] = object
                end
            end

            warn(
                string.format(
                    "[dump] poll %d/%d | total=%d | new=%d",
                    attempt,
                    POLL_TRIES,
                    #objects,
                    #target_objects
                )
            )

            if #target_objects > 0 then
                local ok_dump =
                    dump_now(
                        target_objects
                    )

                if ok_dump then
                    warn(
                        "[dump] filtered scan succeeded"
                    )

                    return
                end
            end
        end

        wait_(
            POLL_GAP
        )
    end

    warn(
        "[dump] no matching prototype structures found"
    )
end)
